# ═══════════════════════════════════════════════════════════════════
# Traffic Sentinel — Environment Variables
# Copy this file to .env and edit as needed:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════

# ── API ──────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1

# ── Dashboard ────────────────────────────────────────────────────
UI_PORT=8501

# ── CORS (comma-separated origins) ──────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:8501","http://localhost:8000"]

# ── YOLO Model ───────────────────────────────────────────────────
# yolov8n.pt  (nano  — fastest, lowest accuracy, recommended for demo)
# yolov8s.pt  (small — good balance)
# yolov8m.pt  (medium — best accuracy, needs more RAM)
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.5
YOLO_IOU=0.45
# Set to "0" to use first GPU, "cpu" for CPU-only
YOLO_DEVICE=cpu

# ── Video Processing ─────────────────────────────────────────────
VIDEO_SAMPLE_INTERVAL=30
VIDEO_FRAME_SAVE_INTERVAL=90
MAX_VIDEO_DURATION_MINUTES=30

# ── Risk Scoring ─────────────────────────────────────────────────
HIGH_TRAFFIC_THRESHOLD=20
MEDIUM_TRAFFIC_THRESHOLD=12
HIGH_RISK_HOUR_BONUS=15
NIGHT_RISK_BONUS=20

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_TO_FILE=false
LOG_FILE=logs/traffic_sentinel.log
